{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/claude-tg-notify",
            "timeout": 30
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/claude-tg-notify",
            "timeout": 30
          }
        ]
      }
    ]
  }
}